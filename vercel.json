{
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/api/(.*)",
      "destination": "/app.py"
    },
    {
      "source": "/admin/(.*)",
      "destination": "/app.py"
    }
  ]
}
