{
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "excludeFiles": "{llm_project/db.sqlite3,**/__pycache__/**,**/*.pyc}"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/app.py"
    },
    {
      "source": "/admin/(.*)",
      "destination": "/app.py"
    }
  ]
}
