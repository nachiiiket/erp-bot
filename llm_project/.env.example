# Django
DEBUG=false
DJANGO_SECRET_KEY=replace-with-generated-django-secret
ALLOWED_HOSTS=localhost,127.0.0.1,.vercel.app
CSRF_TRUSTED_ORIGINS=https://*.vercel.app
CORS_ALLOW_ALL_ORIGINS=false

# LLM
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Optional data path. On Vercel, prefer external storage or commit only safe sample data.
SALES_DATA_DIR=llm_api/data

# Optional MongoDB
MONGO_HOST=
MONGO_PORT=27017
MONGO_DATABASE=
MONGO_USER=
MONGO_PASSWORD=
MONGO_COLLECTION=
MONGO_CHAT_COLLECTION=
MONGO_CPL_DATA_COLLECTION=

# Optional email
EMAIL_HOST=smtp-mail.outlook.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=

# Optional AWS/S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET_NAME=
AWS_PRESIGNED_EXPIRATION=3600

# Optional auth/encryption settings used by utilities/*
APP_HOST=http://localhost:8000
JWT_SECRET_KEY=
OTP_SECRET_KEY=
APP_ENCRYPTION_KEY=
APP_ENCRYPTION_IV=
FERNET_ENCRYPTION_SECRET_KEY=
