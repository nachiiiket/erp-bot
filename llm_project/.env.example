# Django
DEBUG=false
# Required in Vercel production. Generate with:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=replace-with-generated-django-secret
ALLOWED_HOSTS=localhost,127.0.0.1,.vercel.app
CSRF_TRUSTED_ORIGINS=https://*.vercel.app
CORS_ALLOW_ALL_ORIGINS=false

# LLM — NVIDIA
NVIDIA_API_KEY=replace-with-nvidia-api-key
NVIDIA_MODEL=nvidia/nemotron-3-ultra-550b-a55b
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# LLM — OpenAI (optional, if both providers are configured)
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Auth tokens — the one the user enters in the frontend popup selects the provider
NVIDIA_AUTH_TOKEN=replace-with-nvidia-auth-token
OPENAI_AUTH_TOKEN=replace-with-openai-auth-token

# Data. Defaults to the repo-root data/ folder; filenames may be .xlsx or .csv.
SALES_DATA_DIR=data
SALES_ORDERS_FILE=
SALES_ORDER_DETAILS_FILE=
SALES_INVOICE_DETAILS_FILE=

# Optional MongoDB
MONGO_HOST=
MONGO_PORT=27017
MONGO_DATABASE=
MONGO_USER=
MONGO_PASSWORD=
MONGO_COLLECTION=
MONGO_CHAT_COLLECTION=
MONGO_CPL_DATA_COLLECTION=

# Optional email
EMAIL_HOST=smtp-mail.outlook.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=

# Optional AWS/S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET_NAME=
AWS_PRESIGNED_EXPIRATION=3600

# Optional auth/encryption settings used by utilities/*
APP_HOST=http://localhost:8000
JWT_SECRET_KEY=
OTP_SECRET_KEY=
APP_ENCRYPTION_KEY=
APP_ENCRYPTION_IV=
FERNET_ENCRYPTION_SECRET_KEY=
